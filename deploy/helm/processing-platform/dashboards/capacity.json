{
  "uid": "pp-capacity",
  "title": "Processing Platform — Capacity",
  "tags": ["pp", "capacity"],
  "timezone": "",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Kafka backlog trend",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Kafka consumer lag (max per topic, 24h)",
      "description": "Rising trend over hours = need more worker capacity. Note: lag gauge not yet wired; reads 0 until populated.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (topic) (pp_kafka_consumer_lag) or vector(0)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Worker replicas vs HPA target",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Deployment current replicas",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_deployment_status_replicas{deployment=~\"worker-.*\"}",
          "legendFormat": "{{deployment}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HPA desired replicas (Stage 5 placeholder)",
      "description": "HPAs are added in Stage 5. Until then this panel will be empty — that is expected.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas or vector(0)",
          "legendFormat": "{{horizontalpodautoscaler}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Throughput (produce vs consume)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Kafka produce rate (msg/s by topic)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (topic) (rate(pp_kafka_produce_total[5m])) or vector(0)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Kafka consume rate (msg/s by topic)",
      "description": "If produce > consume persistently, backlog is forming.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (topic) (rate(pp_kafka_messages_consumed_total[5m])) or vector(0)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 400,
      "type": "row",
      "title": "Cost (rough)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Estimated $/hr (pods × $0.02)",
      "description": "Order-of-magnitude only — assumes $0.02 per pod-hour. Real cost depends on node type and pod size.",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(kube_pod_info{namespace=\"default\"}) * 0.02",
          "instant": false
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    }
  ]
}
